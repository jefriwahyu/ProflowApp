@model ProflowApp.Models.Pengajuan
@{
    ViewData["Title"] = "Buat Pengajuan";
}

<div class="max-w-lg mx-auto">

    <!-- Header -->
    <div class="mb-6">
        <a asp-controller="Barang" asp-action="Index"
           class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-600 transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Kembali ke Katalog
        </a>
        <h2 class="font-display text-2xl font-bold text-slate-800">Buat Pengajuan Baru</h2>
        <p class="text-sm text-slate-400 mt-0.5">Isi detail barang yang ingin diajukan untuk pengadaan</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

        <!-- Card Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3" style="background-color: #0f172a;">
            <div class="w-8 h-8 bg-sky-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                </svg>
            </div>
            <h5 class="text-white font-semibold text-sm">Form Pengajuan Barang</h5>
        </div>

        <!-- Form Body -->
        <div class="p-6">
            <form asp-action="Create" method="post" class="space-y-5" novalidate
                  onsubmit="event.preventDefault(); confirmAction(this, 'Konfirmasi Pengajuan', 'Apakah Anda yakin ingin mengirimkan pengajuan ini? Pengajuan akan masuk status Pending dan menunggu persetujuan Manager.', 'bg-emerald-500 hover:bg-emerald-400')">

                <!-- Pilih Barang -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Pilih Barang <span class="text-red-400">*</span>
                    </label>
                    <select asp-for="Brg_ID" asp-items="ViewBag.BarangList"
                            class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all appearance-none bg-white">
                        <option value="">-- Pilih Barang --</option>
                    </select>
                    <span asp-validation-for="Brg_ID" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Jumlah -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Jumlah (Quantity) <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="Jml" type="number" min="1"
                           placeholder="Masukkan jumlah"
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="Jml" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Keterangan -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Keterangan <span class="text-red-400">*</span>
                    </label>
                    <textarea asp-for="Keterangan" rows="3"
                              placeholder="Contoh: Untuk kebutuhan pengerjaan proyek di lapangan..."
                              class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all resize-none"></textarea>
                    <span asp-validation-for="Keterangan" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Info Box -->
                <div class="bg-sky-50 border border-sky-100 rounded-xl px-4 py-3 flex gap-3 items-start">
                    <svg class="w-4 h-4 text-sky-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                    </svg>
                    <p class="text-xs text-sky-700 leading-relaxed">
                        Pengajuan akan masuk status <span class="font-semibold">Pending</span> dan menunggu persetujuan Manager sebelum diproses menjadi Purchase Order.
                    </p>
                </div>

                <!-- Actions -->
                <div class="flex items-center justify-end gap-3 pt-1">
                    <a asp-controller="Barang" asp-action="Index"
                       class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2.5 rounded-xl transition-all duration-150">
                        Batal
                    </a>
                    <button type="submit"
                            class="bg-emerald-500 hover:bg-emerald-400 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-emerald-500/20 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                        </svg>
                        Kirim Pengajuan
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="detailModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">

            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between" style="background-color: #0f172a;">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z" />
                        </svg>
                    </div>
                    <h3 id="modalTitle" class="text-white font-semibold text-sm">Konfirmasi</h3>
                </div>
                <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5">
                <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-4">
                    <p id="modalContent" class="text-sm text-emerald-700 leading-relaxed break-words"></p>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                <button onclick="closeModal()"
                        class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2 rounded-xl transition-all">
                    Batal
                </button>
                <button id="confirmBtn"
                        class="hidden px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all">
                    Ya, Kirim
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const modal = document.getElementById('detailModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalContent = document.getElementById('modalContent');
        const confirmBtn = document.getElementById('confirmBtn');
        let currentForm = null;

        function confirmAction(form, actionTitle, message, colorClass) {
            currentForm = form;
            modalTitle.innerText = actionTitle;
            modalContent.innerText = message;
            confirmBtn.className = `px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all ${colorClass}`;
            confirmBtn.innerText = "Ya, Kirim";
            confirmBtn.classList.remove('hidden');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        confirmBtn.onclick = function () {
            if (currentForm) currentForm.submit();
        }

        function closeModal() {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            currentForm = null;
        }

        // Tutup modal saat klik backdrop
        modal.addEventListener('click', function (e) {
            if (e.target === modal.firstElementChild) closeModal();
        });
    </script>
}
