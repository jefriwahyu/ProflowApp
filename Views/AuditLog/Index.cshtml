@model IEnumerable<ProflowApp.Models.AuditLog>
@{
    ViewData["Title"] = "Monitor Aktivitas";
    var allActions = ViewBag.AllActions as List<string> ?? new List<string>();
}

<!-- Header -->
<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="font-display text-2xl font-bold text-slate-800">Monitor Aktivitas</h2>
        <p class="text-sm text-slate-400 mt-0.5">Log semua aktivitas pengguna di sistem</p>
    </div>
    <div class="bg-white border border-slate-100 rounded-xl px-4 py-2 text-xs text-slate-500 shadow-sm">
        Total <span class="font-bold text-slate-700">@ViewBag.TotalData</span> aktivitas
    </div>
</div>

<!-- Filter Form -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-4">
    <div class="px-5 py-3.5 flex items-center gap-3" style="background-color:#0f172a;">
        <div class="w-7 h-7 bg-sky-500/20 rounded-lg flex items-center justify-center">
            <svg style="width:14px;height:14px" class="text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/>
            </svg>
        </div>
        <h5 class="text-white font-semibold text-sm">Filter</h5>
    </div>
    <div class="p-5">
        <form method="get" asp-action="Index">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                <!-- Search -->
                <div class="lg:col-span-2">
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">
                        Cari
                        <span class="normal-case font-normal text-slate-400">— Username atau Detail</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                            </svg>
                        </div>
                        <input type="text" name="search" value="@ViewBag.FilterSearch"
                               placeholder="Ketik username atau detail aktivitas..."
                               class="w-full border border-slate-200 rounded-lg pl-9 pr-3 py-2 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all"/>
                    </div>
                </div>
                <!-- Action -->
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">Tipe Aktivitas</label>
                    <select name="tipeAktivitas"
                            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-800 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all">
                        <option value="">Semua Aktivitas</option>
                        @foreach (var act in allActions)
                        {
                            <option value="@act" selected="@(ViewBag.FilterTipeAktivitas == act)">@act</option>
                        }
                    </select>
                </div>
                <!-- Tanggal Dari -->
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">Tanggal Dari</label>
                    <input type="date" name="tanggalDari" value="@ViewBag.FilterTanggalDari"
                           class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-800 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all"/>
                </div>
                <!-- Tanggal Sampai -->
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">Tanggal Sampai</label>
                    <input type="date" name="tanggalSampai" value="@ViewBag.FilterTanggalSampai"
                           class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-800 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all"/>
                </div>
            </div>
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                <a asp-action="Index"
                   class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-3.5 py-2 rounded-lg transition-all">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
                    </svg>
                    Reset
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-1.5 bg-sky-500 hover:bg-sky-400 text-white text-xs font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm shadow-sky-500/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                    </svg>
                    Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr style="background-color:#0f172a;">
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">Waktu</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">Username</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">Role</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">Aktivitas</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">Detail</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-5 py-4">IP Address</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-16 text-slate-400">
                        <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                        </svg>
                        <p class="font-medium">Tidak ada log aktivitas</p>
                        <p class="text-xs mt-1">Coba ubah filter pencarian</p>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <!-- Waktu -->
                        <td class="px-5 py-3.5 text-xs text-slate-500 whitespace-nowrap">
                            @item.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")
                        </td>
                        <!-- Username -->
                        <td class="px-5 py-3.5">
                            @if (!string.IsNullOrEmpty(item.Username))
                            {
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-bold text-xs shrink-0">
                                        @item.Username.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="text-xs font-medium text-slate-700">@item.Username</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-slate-300 text-xs">—</span>
                            }
                        </td>
                        <!-- Role -->
                        <td class="px-5 py-3.5">
                            @if (!string.IsNullOrEmpty(item.Role))
                            {
                                <span class="text-xs font-medium px-2 py-0.5 rounded-full
                                    @(item.Role == "Manager" ? "bg-sky-50 text-sky-600 border border-sky-200" :
                                      item.Role == "Checker" ? "bg-emerald-50 text-emerald-600 border border-emerald-200" :
                                      "bg-slate-50 text-slate-600 border border-slate-200")">
                                    @item.Role
                                </span>
                            }
                            else
                            {
                                <span class="text-slate-300 text-xs">—</span>
                            }
                        </td>
                        <!-- Action Badge -->
                        <td class="px-5 py-3.5">
                            @{
                                var badgeClass = item.Action switch
                                {
                                    "LOGIN"            => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                    "LOGOUT"           => "bg-slate-50 text-slate-600 border-slate-200",
                                    "LOGIN_FAILED"     => "bg-red-50 text-red-600 border-red-200",
                                    "LOGIN_BLOCKED"    => "bg-red-50 text-red-600 border-red-200",
                                    "ACCOUNT_LOCKED"   => "bg-red-50 text-red-700 border-red-200",
                                    "RATE_LIMITED"     => "bg-orange-50 text-orange-600 border-orange-200",
                                    "CHANGE_PASSWORD"  => "bg-amber-50 text-amber-700 border-amber-200",
                                    "CREATE_USER"      => "bg-sky-50 text-sky-700 border-sky-200",
                                    "EDIT_USER"        => "bg-amber-50 text-amber-700 border-amber-200",
                                    "DELETE_USER"      => "bg-red-50 text-red-600 border-red-200",
                                    "RESTORE_USER"     => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                    "CREATE_BARANG"    => "bg-sky-50 text-sky-700 border-sky-200",
                                    "EDIT_BARANG"      => "bg-amber-50 text-amber-700 border-amber-200",
                                    "DELETE_BARANG"    => "bg-red-50 text-red-600 border-red-200",
                                    "RESTORE_BARANG"   => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                    "CREATE_PR"        => "bg-sky-50 text-sky-700 border-sky-200",
                                    "APPROVE_PR"       => "bg-emerald-50 text-emerald-700 border-emerald-200",
                                    "REJECT_PR"        => "bg-red-50 text-red-600 border-red-200",
                                    "ASSIGN_CHECKER"   => "bg-blue-50 text-blue-700 border-blue-200",
                                    "KIRIM_BUKTI"      => "bg-purple-50 text-purple-700 border-purple-200",
                                    "SUDAH_DICEK"      => "bg-purple-50 text-purple-700 border-purple-200",
                                    _                  => "bg-slate-50 text-slate-600 border-slate-200"
                                };
                            }
                            <span class="inline-flex text-xs font-semibold px-2 py-0.5 rounded-full border whitespace-nowrap @badgeClass">
                                @item.Action
                            </span>
                        </td>
                        <!-- Detail -->
                        <td class="px-5 py-3.5 text-xs text-slate-600 max-w-xs truncate" title="@item.Detail">
                            @item.Detail
                        </td>
                        <!-- IP -->
                        <td class="px-5 py-3.5 text-xs text-slate-400 font-mono whitespace-nowrap">
                            @(item.IpAddress ?? "—")
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <div class="px-5 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
        <span class="text-xs text-slate-400">
            Halaman <span class="font-semibold text-slate-600">@ViewBag.CurrentPage</span>
            dari <span class="font-semibold text-slate-600">@ViewBag.TotalPages</span>
        </span>
        <div class="flex items-center gap-2">
            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage - 1)"
               asp-route-search="@ViewBag.FilterSearch"
               asp-route-tipeAktivitas="@ViewBag.FilterTipeAktivitas"
               asp-route-tanggalDari="@ViewBag.FilterTanggalDari"
               asp-route-tanggalSampai="@ViewBag.FilterTanggalSampai"
               class="@(ViewBag.CurrentPage <= 1 ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
                </svg>
                Prev
            </a>
            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage + 1)"
               asp-route-search="@ViewBag.FilterSearch"
               asp-route-tipeAktivitas="@ViewBag.FilterTipeAktivitas"
               asp-route-tanggalDari="@ViewBag.FilterTanggalDari"
               asp-route-tanggalSampai="@ViewBag.FilterTanggalSampai"
               class="@(ViewBag.CurrentPage >= ViewBag.TotalPages ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                Next
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                </svg>
            </a>
        </div>
    </div>
</div>