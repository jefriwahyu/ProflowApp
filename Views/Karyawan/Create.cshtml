@model ProflowApp.Models.User
@{
    ViewData["Title"] = "Tambah Karyawan";
}

<div class="max-w-lg mx-auto">

    <!-- Header -->
    <div class="mb-6">
        <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-600 transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            Kembali ke Daftar
        </a>
        <h2 class="font-display text-2xl font-bold text-slate-800">Tambah Karyawan</h2>
        <p class="text-sm text-slate-400 mt-0.5">Isi data berikut untuk membuat akun karyawan baru</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

        <!-- Card Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3" style="background-color: #0f172a;">
            <div class="w-8 h-8 bg-sky-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
                </svg>
            </div>
            <h5 class="text-white font-semibold text-sm">Form Data Karyawan</h5>
        </div>

        <!-- Form Body -->
        <div class="p-6 space-y-5">
            <form asp-action="Create" method="post"
                  onsubmit="event.preventDefault(); confirmAction(this, 'Konfirmasi Tambah Karyawan', 'Apakah Anda yakin ingin membuat akun karyawan baru ini?', 'bg-emerald-500 hover:bg-emerald-400')">

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm bg-red-50 border border-red-100 rounded-xl px-4 py-3 mb-2"></div>

                <!-- Nama Lengkap -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Nama Lengkap <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="Nama" required
                           placeholder="Contoh: Budi Santoso"
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="Nama" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Username -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Username <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm">@@</span>
                        <input asp-for="Username" required
                               placeholder="huruf kecil, tanpa spasi"
                               class="w-full border border-slate-200 rounded-xl pl-8 pr-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    </div>
                    <span asp-validation-for="Username" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Password -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Password <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="Password" type="password" required
                           placeholder="Minimal 6 karakter"
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Info Role -->
                <div class="mb-1.5 mt-3">
                    <input type="hidden" asp-for="Role" value="Karyawan" />
                    <div class="p-3 bg-sky-50 rounded-xl border border-sky-100">
                        <p class="text-xs text-sky-700 font-medium flex items-center gap-2">
                            <svg class="w-4 h-4 text-sky-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                            </svg>
                            Akun baru akan otomatis terdaftar dengan hak akses Karyawan.
                        </p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex items-center justify-end gap-3 pt-2">
                    <a asp-action="Index"
                       class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2.5 rounded-xl transition-all duration-150">
                        Batal
                    </a>
                    <button type="submit"
                            class="bg-emerald-500 hover:bg-emerald-400 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-emerald-500/20 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Simpan Data
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="detailModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">

            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between" style="background-color: #0f172a;">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/>
                        </svg>
                    </div>
                    <h3 id="modalTitle" class="text-white font-semibold text-sm">Konfirmasi</h3>
                </div>
                <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5">
                <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-4">
                    <p id="modalContent" class="text-sm text-emerald-700 leading-relaxed break-words"></p>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                <button onclick="closeModal()"
                        class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2 rounded-xl transition-all">
                    Batal
                </button>
                <button id="confirmBtn"
                        class="hidden px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all">
                    Ya, Simpan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        const modal = document.getElementById('detailModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalContent = document.getElementById('modalContent');
        const confirmBtn = document.getElementById('confirmBtn');
        let currentForm = null;

        function confirmAction(form, actionTitle, message, colorClass) {
            currentForm = form;
            modalTitle.innerText = actionTitle;
            modalContent.innerText = message;
            confirmBtn.className = `px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all ${colorClass}`;
            confirmBtn.innerText = "Ya, Simpan";
            confirmBtn.classList.remove('hidden');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        confirmBtn.onclick = function () {
            if (currentForm) currentForm.submit();
        }

        function closeModal() {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            currentForm = null;
        }

        modal.addEventListener('click', function (e) {
            if (e.target === modal.firstElementChild) closeModal();
        });
    </script>
}
