@model IEnumerable<ProflowApp.Models.User>
@{
    ViewData["Title"] = "Kelola Karyawan";
}

<!-- Header -->
<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="font-display text-2xl font-bold text-slate-800">Kelola Karyawan</h2>
        <p class="text-sm text-slate-400 mt-0.5">Manajemen akun karyawan</p>
    </div>
    <div class="flex items-center gap-3">
        <a asp-action="Trash"
           class="bg-slate-800 hover:bg-slate-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 shadow-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Karyawan Nonaktif
        </a>
        <a asp-action="Create"
           class="bg-sky-500 hover:bg-sky-400 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-sky-500/20 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
            </svg>
            Tambah Karyawan
        </a>
    </div>
</div>

<!-- Success/Error -->
@if (TempData["Success"] != null)
{
    <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm px-4 py-3 rounded-xl mb-4">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-xl mb-4">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
        </svg>
        @TempData["Error"]
    </div>
}

<!-- Filter Form -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-4">
    <div class="px-5 py-3.5 flex items-center gap-3" style="background-color:#0f172a;">
        <div class="w-7 h-7 bg-sky-500/20 rounded-lg flex items-center justify-center">
            <svg style="width:14px;height:14px" class="text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
            </svg>
        </div>
        <h5 class="text-white font-semibold text-sm">Pencarian</h5>
    </div>
    <div class="p-5">
        <form method="get" asp-action="Index">
            <div class="flex items-end gap-3">
                <!-- Search Box -->
                <div class="flex-1">
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">
                        Cari
                        <span class="normal-case font-normal text-slate-400">— ID Pegawai, Nama Lengkap, atau Username</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                            </svg>
                        </div>
                        <input type="text" name="search" value="@ViewBag.FilterSearch"
                               placeholder="Ketik ID pegawai, nama lengkap, atau username..."
                               class="w-full border border-slate-200 rounded-lg pl-9 pr-3 py-2 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all"/>
                    </div>
                </div>
                <!-- Tombol -->
                <div class="flex items-center gap-2">
                    <a asp-action="Index"
                       class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-3.5 py-2 rounded-lg transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
                        </svg>
                        Reset
                    </a>
                    <button type="submit"
                            class="inline-flex items-center gap-1.5 bg-sky-500 hover:bg-sky-400 text-white text-xs font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm shadow-sky-500/20">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                        </svg>
                        Cari
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table Card -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-slate-100" style="background-color: #0f172a;">
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">ID Pegawai</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Nama Lengkap</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Username</th>
                <th class="text-center text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Aksi</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-16 text-slate-400">
                        <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                        </svg>
                        @if (!string.IsNullOrEmpty(ViewBag.FilterSearch as string))
                        {
                            <p class="font-medium">Tidak ada hasil untuk "<span class="text-sky-500">@ViewBag.FilterSearch</span>"</p>
                            <p class="text-xs mt-1">Coba kata kunci yang berbeda</p>
                        }
                        else
                        {
                            <p class="font-medium">Belum ada data karyawan</p>
                            <p class="text-xs mt-1">Tambahkan karyawan pertama dengan tombol di atas</p>
                        }
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors duration-100">
                        <!-- ID -->
                        <td class="px-6 py-4">
                            <span class="font-mono text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-lg">#@item.UserID</span>
                        </td>
                        <!-- Nama -->
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 font-semibold text-xs shrink-0">
                                    @item.Nama.Substring(0, 1).ToUpper()
                                </div>
                                <span class="font-medium text-slate-800">@item.Nama</span>
                            </div>
                        </td>
                        <!-- Username -->
                        <td class="px-6 py-4 text-slate-500">@item.Username</td>
                        <!-- Aksi -->
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.UserID"
                                   class="text-xs font-medium text-amber-600 hover:text-amber-700 border border-amber-200 hover:border-amber-300 hover:bg-amber-50 px-3 py-1.5 rounded-lg transition-all duration-150">
                                    Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.UserID" method="post"
                                      onsubmit="event.preventDefault(); confirmAction(this, 'Nonaktifkan Karyawan', 'Apakah Anda yakin ingin menonaktifkan akun @item.Nama? Karyawan ini tidak akan bisa login lagi.', 'bg-red-600 hover:bg-red-500')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="text-xs font-medium text-red-500 hover:text-red-600 border border-red-200 hover:border-red-300 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all duration-150">
                                        Hapus
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (Model.Any())
    {
        <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
            <span class="text-xs text-slate-400">
                Menampilkan <span class="font-semibold text-slate-600">@Model.Count()</span>
                dari <span class="font-semibold text-slate-600">@ViewBag.TotalItems</span> karyawan
            </span>
            <div class="flex items-center gap-2">
                <a asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-search="@ViewBag.FilterSearch"
                   class="@(ViewBag.CurrentPage <= 1 ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
                    </svg>
                    Prev
                </a>
                <a asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-search="@ViewBag.FilterSearch"
                   class="@(ViewBag.CurrentPage >= ViewBag.TotalPages ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                    Next
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                    </svg>
                </a>
            </div>
        </div>
    }
</div>

<!-- Modal Konfirmasi -->
<div id="detailModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between" style="background-color: #0f172a;">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-red-500/20 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/>
                        </svg>
                    </div>
                    <h3 id="modalTitle" class="text-white font-semibold text-sm">Konfirmasi</h3>
                </div>
                <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div class="px-6 py-5">
                <div class="flex items-start gap-3 bg-red-50 border border-red-100 rounded-xl p-4">
                    <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                    <p id="modalContent" class="text-sm text-red-700 leading-relaxed"></p>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                <button onclick="closeModal()"
                        class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2 rounded-xl transition-all">
                    Batal
                </button>
                <button id="confirmBtn" class="hidden px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all">
                    Ya, Nonaktifkan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal     = document.getElementById('detailModal');
        const modalTitle   = document.getElementById('modalTitle');
        const modalContent = document.getElementById('modalContent');
        const confirmBtn   = document.getElementById('confirmBtn');
        let currentForm = null;

        function confirmAction(form, actionTitle, message, colorClass) {
            currentForm = form;
            modalTitle.innerText   = actionTitle;
            modalContent.innerText = message;
            confirmBtn.className   = `px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all ${colorClass}`;
            confirmBtn.innerText   = "Ya, Nonaktifkan";
            confirmBtn.classList.remove('hidden');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        confirmBtn.onclick = function () {
            if (currentForm) currentForm.submit();
        }

        function closeModal() {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            currentForm = null;
        }

        modal.addEventListener('click', function (e) {
            if (e.target === modal.firstElementChild) closeModal();
        });
    </script>
}