@{
    ViewData["Title"] = "Bantuan Akses";
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bantuan Akses - ProFlowApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['DM Sans', 'sans-serif'],
                        display: ['Syne', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'DM Sans', sans-serif; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center" style="background: linear-gradient(135deg, #0a0f1e 0%, #0f2744 50%, #0a0f1e 100%);">

    <!-- Background grid decoration -->
    <div class="fixed inset-0 opacity-5 pointer-events-none" style="background-image: linear-gradient(#38bdf8 1px, transparent 1px), linear-gradient(90deg, #38bdf8 1px, transparent 1px); background-size: 50px 50px;"></div>

    <!-- Glow effect -->
    <div class="fixed top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(56,189,248,0.08), transparent 70%);"></div>

    <div class="relative z-10 w-full max-w-sm px-6">

        <!-- Brand -->
        <div class="text-center mb-8">
            <h1 class="font-display text-3xl font-bold text-white mb-1">
                <span class="text-sky-400">Pro</span>Flow
            </h1>
            <p class="text-slate-400 text-sm">E-Procurement System</p>
        </div>

        <!-- Card -->
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl overflow-hidden shadow-2xl">

            <!-- Card Header -->
            <div class="px-6 py-4 border-b border-white/10 flex items-center gap-3" style="background-color: rgba(15,23,42,0.8);">
                <div class="w-8 h-8 bg-red-500/20 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                    </svg>
                </div>
                <h5 class="text-white font-semibold text-sm">Akses Terkunci?</h5>
            </div>

            <!-- Card Body -->
            <div class="px-6 py-6 space-y-4">

                <!-- Info box -->
                <div class="bg-white/5 border border-white/10 rounded-xl p-4 space-y-3">
                    <p class="text-sm text-slate-300 leading-relaxed">
                        Demi keamanan integritas data perusahaan, sistem <span class="font-semibold text-white">tidak mengizinkan</span> reset password secara mandiri melalui halaman ini.
                    </p>
                    <div class="border-t border-white/10 pt-3 flex items-start gap-2">
                        <svg class="w-4 h-4 text-sky-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </svg>
                        <p class="text-sm text-slate-300 leading-relaxed">
                            Silakan hubungi <span class="font-semibold text-sky-400">Manager Operasional</span> Anda secara langsung untuk meminta pembuatan password baru.
                        </p>
                    </div>
                </div>

                <!-- Back button -->
                <a asp-action="Login"
                   class="w-full bg-sky-500 hover:bg-sky-400 text-white text-sm font-semibold py-3 rounded-xl transition-colors duration-200 shadow-lg shadow-sky-500/25 flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
                    </svg>
                    Kembali ke Halaman Login
                </a>
            </div>
        </div>

        <!-- Footer -->
        <p class="text-center text-slate-600 text-xs mt-6">&copy; 2026 ProFlowApp</p>
    </div>

</body>
</html>
