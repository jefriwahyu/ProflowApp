@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - ProFlow</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@700;800&display=swap"
          rel="stylesheet">
    <script>
        tailwind.config = {
        theme: {
        extend: {
        fontFamily: {
        sans: ['DM Sans', 'sans-serif'],
        display: ['Syne', 'sans-serif'],
        }
        }
        }
        }
    </script>
    <style>
        body {
        font-family: 'DM Sans', sans-serif;
        }
        .input-field {
        transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-field:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center"
      style="background: linear-gradient(135deg, #0a0f1e 0%, #0f2744 50%, #0a0f1e 100%);">

    <!-- Background grid decoration -->
    <div class="fixed inset-0 opacity-5 pointer-events-none"
         style="background-image: linear-gradient(#38bdf8 1px, transparent 1px), linear-gradient(90deg, #38bdf8 1px, transparent 1px); background-size: 50px 50px;">
    </div>

    <!-- Glow effect -->
    <div class="fixed top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(56,189,248,0.08), transparent 70%);"></div>

    <div class="relative z-10 w-full max-w-sm px-6">

        <!-- Brand -->
        <div class="text-center mb-8">
            <h1 class="font-display text-3xl font-bold text-white mb-1">
                <span class="text-sky-400">Pro</span>Flow
            </h1>
            <p class="text-slate-400 text-sm">E-Procurement System</p>
        </div>

        <!-- Card -->
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 shadow-2xl">
            <h2 class="text-white font-semibold text-lg mb-6">Masuk ke Akun Anda</h2>

            <form asp-action="Login" method="post" class="space-y-5">

                <!-- Username -->
                <div>
                    <label class="block text-sm text-slate-300 mb-1.5 font-medium">Username</label>
                    <input type="text" name="username" required
                           class="input-field w-full bg-white/8 border border-white/20 text-white placeholder-slate-500 rounded-xl px-4 py-3 text-sm"
                           style="background: rgba(255,255,255,0.07);"                           placeholder="Masukkan username" />
                </div>

                <!-- Password -->
                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <label class="block text-sm text-slate-300 font-medium">Password</label>

                        <a asp-controller="Account" asp-action="ForgotPassword"
                               class="text-xs font-medium text-sky-400 hover:text-sky-300 transition-colors duration-200">
                            Lupa password?
                        </a>
                    </div>
                    <input type="password" name="password" required
                           class="input-field w-full border border-white/20 text-white placeholder-slate-500 rounded-xl px-4 py-3 text-sm"
                           style="background: rgba(255,255,255,0.07);"           placeholder="Masukkan password" />
                </div>

                <!-- Error Message -->
                @if (ViewBag.Error != null)
                {
                    <div      class="flex items-center gap-2 bg-red-500/10 border border-red-500/30 text-red-400 text-sm px-4 py-3 rounded-xl">
                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                             viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                        </svg>
                        @ViewBag.Error
                    </div>
                }

                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-sky-500 hover:bg-sky-400 active:bg-sky-600 text-white font-semibold py-3 rounded-xl transition-all duration-200 shadow-lg shadow-sky-500/25 mt-2">
                    Masuk
                </button>

            </form>

        </div>

        <!-- Footer -->
        <p class="text-center text-slate-600 text-xs mt-6">&copy; 2026 ProFlowApp</p>
    </div>

</body>

</html>