@model ProflowApp.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Ganti Password";
}

<div class="max-w-lg mx-auto">

    <!-- Header -->
    <div class="mb-6">
        <h2 class="font-display text-2xl font-bold text-slate-800">Ganti Password</h2>
        <p class="text-sm text-slate-400 mt-0.5">Pastikan akun Anda tetap aman dengan password yang kuat</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

        <!-- Card Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3" style="background-color: #0f172a;">
            <div class="w-8 h-8 bg-sky-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/>
                </svg>
            </div>
            <h5 class="text-white font-semibold text-sm">Form Ganti Password</h5>
        </div>

        <!-- Form Body -->
        <div class="p-6">
            <form asp-action="ChangePassword" method="post" class="space-y-5"
                  onsubmit="event.preventDefault(); confirmAction(this, 'Konfirmasi Ganti Password', 'Apakah Anda yakin ingin mengganti password akun Anda?', 'bg-sky-500 hover:bg-sky-400')">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-red-500 text-sm bg-red-50 border border-red-100 rounded-xl px-4 py-3"></div>

                <!-- Password Lama -->
                <div>
                    <label asp-for="PasswordLama" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Password Lama <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="PasswordLama" type="password"
                           placeholder="Masukkan password saat ini..."
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="PasswordLama" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Password Baru -->
                <div>
                    <label asp-for="PasswordBaru" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Password Baru <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="PasswordBaru" type="password"
                           placeholder="Minimal 6 karakter..."
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="PasswordBaru" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Konfirmasi Password -->
                <div>
                    <label asp-for="KonfirmasiPassword" class="block text-sm font-semibold text-slate-700 mb-1.5">
                        Ketik Ulang Password Baru <span class="text-red-400">*</span>
                    </label>
                    <input asp-for="KonfirmasiPassword" type="password"
                           placeholder="Ulangi password baru..."
                           class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    <span asp-validation-for="KonfirmasiPassword" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Info box -->
                <div class="p-3 bg-sky-50 rounded-xl border border-sky-100">
                    <p class="text-xs text-sky-700 font-medium flex items-center gap-2">
                        <svg class="w-4 h-4 text-sky-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </svg>
                        Setelah password diganti, Anda akan tetap dalam sesi yang sama.
                    </p>
                </div>

                <!-- Actions -->
                <div class="flex items-center justify-end gap-3 pt-1">
                    <a asp-controller="Home" asp-action="Index"
                       class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2.5 rounded-xl transition-all duration-150">
                        Batal
                    </a>
                    <button type="submit"
                            class="bg-sky-500 hover:bg-sky-400 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors duration-200 shadow-sm shadow-sky-500/20 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Simpan Password
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="detailModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">

            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between" style="background-color: #0f172a;">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-sky-500/20 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/>
                        </svg>
                    </div>
                    <h3 id="modalTitle" class="text-white font-semibold text-sm">Konfirmasi</h3>
                </div>
                <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5">
                <div class="bg-sky-50 border border-sky-100 rounded-xl p-4">
                    <p id="modalContent" class="text-sm text-sky-700 leading-relaxed break-words"></p>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                <button onclick="closeModal()"
                        class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2 rounded-xl transition-all">
                    Batal
                </button>
                <button id="confirmBtn"
                        class="hidden px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all">
                    Ya, Simpan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const modal = document.getElementById('detailModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalContent = document.getElementById('modalContent');
        const confirmBtn = document.getElementById('confirmBtn');
        let currentForm = null;

        function confirmAction(form, actionTitle, message, colorClass) {
            currentForm = form;
            modalTitle.innerText = actionTitle;
            modalContent.innerText = message;
            confirmBtn.className = `px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all ${colorClass}`;
            confirmBtn.innerText = "Ya, Simpan";
            confirmBtn.classList.remove('hidden');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        confirmBtn.onclick = function () {
            if (currentForm) currentForm.submit();
        }

        function closeModal() {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            currentForm = null;
        }

        modal.addEventListener('click', function (e) {
            if (e.target === modal.firstElementChild) closeModal();
        });
    </script>
}
