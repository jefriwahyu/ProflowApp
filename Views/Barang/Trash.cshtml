@model IEnumerable<ProflowApp.Models.Barang>
@{
    ViewData["Title"] = "Tempat Sampah - Katalog Barang";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <a asp-action="Index"
           class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-600 transition-colors mb-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Kembali ke Katalog Utama
        </a>
        <h2 class="font-display text-2xl font-bold text-slate-800">Tempat Sampah</h2>
        <p class="text-sm text-slate-400 mt-0.5">Daftar barang yang telah dihapus sementara (Soft Deleted)</p>
    </div>
</div>

<!-- Filter Form -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-4">
    <div class="px-5 py-3.5 flex items-center gap-3" style="background-color:#0f172a;">
        <div class="w-7 h-7 bg-sky-500/20 rounded-lg flex items-center justify-center">
            <svg style="width:14px;height:14px" class="text-sky-400" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
        </div>
        <h5 class="text-white font-semibold text-sm">Pencarian</h5>
    </div>
    <div class="p-5">
        <form method="get" asp-action="Trash">
            <div class="flex items-end gap-3">
                <div class="flex-1">
                    <label class="block text-xs font-semibold text-slate-500 mb-1 uppercase tracking-wide">
                        Cari
                        <span class="normal-case font-normal text-slate-400">— Nama Barang</span>
                    </label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                            </svg>
                        </div>
                        <input type="text" name="search" value="@ViewBag.FilterSearch"
                               placeholder="Ketik nama barang..."
                               class="w-full border border-slate-200 rounded-lg pl-9 pr-3 py-2 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/20 transition-all" />
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a asp-action="Trash"
                       class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-3.5 py-2 rounded-lg transition-all">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                        </svg>
                        Reset
                    </a>
                    <button type="submit"
                            class="inline-flex items-center gap-1.5 bg-sky-500 hover:bg-sky-400 text-white text-xs font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm shadow-sky-500/20">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                        </svg>
                        Cari
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table Card -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr style="background-color: #0f172a;">
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">ID</th>
                <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Nama
                    Barang</th>
                    <th class="text-left text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Vendor
                    </th>
                    <th class="text-center text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Satuan
                    </th>
                    <th class="text-right text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Estimasi
                        Harga</th>
                        <th class="text-center text-xs font-semibold text-slate-300 uppercase tracking-wider px-6 py-4">Aksi
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-16 text-slate-400">
                                <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor"
                                     stroke-width="1.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                @if (!string.IsNullOrEmpty(ViewBag.FilterSearch as string))
                                {
                                    <p class="font-medium">Tidak ada hasil untuk "<span
                                        class="text-sky-500">@ViewBag.FilterSearch</span>"</p>
                                        <p class="text-xs mt-1">Coba kata kunci yang berbeda</p>
                                    }
                        else
                                    {
                                        <p class="font-medium">Tempat sampah kosong</p>
                                        <p class="text-xs mt-1">Barang yang dihapus akan muncul di sini</p>
                                    }
                                </td>
                            </tr>
                        }
            else
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-50 transition-colors duration-100">
                                    <td class="px-6 py-4">
                                        <span
                                        class="font-mono text-xs bg-slate-100 text-slate-500 px-2 py-1 rounded-lg">#@item.Brg_ID</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="font-medium text-slate-400 line-through">@item.Nm_Brg</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="text-xs text-slate-400">@item.Nm_Vendor</span>
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <span
                                        class="bg-slate-100 text-slate-400 text-xs font-medium px-2.5 py-1 rounded-full">@item.Satuan</span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <span class="font-semibold text-slate-400">Rp @((item.Hrg_Est ?? 0).ToString("N0"))</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <form asp-action="Restore" asp-route-id="@item.Brg_ID" method="post"
                                              onsubmit="event.preventDefault(); confirmAction(this, 'Restore Barang', 'Apakah Anda yakin ingin mengembalikan \'@item.Nm_Brg\' ke katalog aktif?', 'bg-emerald-500 hover:bg-emerald-400')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="text-xs font-semibold text-emerald-600 hover:text-emerald-700 border border-emerald-200 hover:bg-emerald-50 px-3 py-1.5 rounded-lg transition-all flex items-center gap-1.5 mx-auto">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"
                                                     viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                          d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                                </svg>
                                                Restore
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <!-- Pagination -->
                @if (Model.Any())
                {
                    <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
                        <span class="text-xs text-slate-400">
                            Halaman <span class="font-semibold text-slate-600">@ViewBag.CurrentPage</span>
                            dari <span class="font-semibold text-slate-600">@ViewBag.TotalPages</span>
                        </span>
                        <div class="flex items-center gap-2">
                            <a asp-action="Trash" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-search="@ViewBag.FilterSearch"
                               class="@(ViewBag.CurrentPage <= 1 ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                </svg>
                                Prev
                            </a>
                            <a asp-action="Trash" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-search="@ViewBag.FilterSearch"
                               class="@(ViewBag.CurrentPage >= ViewBag.TotalPages ? "pointer-events-none opacity-30" : "hover:bg-slate-200") text-xs font-medium text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                                Next
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- Confirmation Modal -->
            <div id="detailModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
                <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm"></div>
                <div class="flex min-h-full items-center justify-center p-4">
                    <div class="relative w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between"
                             style="background-color: #0f172a;">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-emerald-500/20 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                    </svg>
                                </div>
                                <h3 id="modalTitle" class="text-white font-semibold text-sm">Konfirmasi</h3>
                            </div>
                            <button onclick="closeModal()" class="text-slate-400 hover:text-white transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                        <div class="px-6 py-5">
                            <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-4">
                                <p id="modalContent" class="text-sm text-emerald-700 leading-relaxed break-words"></p>
                            </div>
                        </div>
                        <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                            <button onclick="closeModal()"
                                    class="text-sm font-medium text-slate-500 hover:text-slate-700 border border-slate-200 hover:border-slate-300 px-4 py-2 rounded-xl transition-all">
                                Batal
                            </button>
                            <button id="confirmBtn"
                                    class="hidden px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all">
                                Ya, Restore
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @section Scripts {
                <script>
                    const modal = document.getElementById('detailModal');
                    const modalTitle = document.getElementById('modalTitle');
                    const modalContent = document.getElementById('modalContent');
                    const confirmBtn = document.getElementById('confirmBtn');
                    let currentForm = null;

                    function confirmAction(form, actionTitle, message, colorClass) {
                        currentForm = form;
                        modalTitle.innerText = actionTitle;
                        modalContent.innerText = message;
                        confirmBtn.className = `px-5 py-2 rounded-xl text-sm font-semibold text-white transition-all ${colorClass}`;
                        confirmBtn.innerText = "Ya, Restore";
                        confirmBtn.classList.remove('hidden');
                        modal.classList.remove('hidden');
                        document.body.style.overflow = 'hidden';
                    }

                    confirmBtn.onclick = function () {
                        if (currentForm) currentForm.submit();
                    }

                    function closeModal() {
                        modal.classList.add('hidden');
                        document.body.style.overflow = 'auto';
                        currentForm = null;
                    }

                    modal.addEventListener('click', function (e) {
                        if (e.target === modal.firstElementChild) closeModal();
                    });
                </script>
            }